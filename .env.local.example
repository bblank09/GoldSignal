# ═══════════════════════════════════════════════════════════════════════════════
#  GoldSignal — Environment Variables
#
#  QUICK START (Mock Mode — ไม่ต้องมี API key ใดๆ):
#    1. cp .env.local.example .env.local
#    2. npm run dev
#    → เปิด http://localhost:3000 ได้ทันที ข้อมูลเป็น mock data
#
#  LIVE MODE — ต้องการ API keys ครบทุกตัว:
#    แก้ DATA_MODE=live แล้วกรอก keys ด้านล่าง
# ═══════════════════════════════════════════════════════════════════════════════

# ── Data Mode ──────────────────────────────────────────────────────────────────
# 'mock' = ใช้ข้อมูลจาก lib/mock-data.ts (ไม่ต้องการ external APIs)
# 'live' = ดึงข้อมูลจริงจาก Supabase, Redis, Yahoo Finance, Anthropic Claude
DATA_MODE=mock
NEXT_PUBLIC_DATA_SOURCE=mock

# ── App URL ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (ต้องการเฉพาะ Live Mode) ─────────────────────────────────────────
# Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Settings → API → service_role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Upstash Redis (ต้องการเฉพาะ Live Mode) ────────────────────────────────────
# upstash.com → Database → REST API → URL
UPSTASH_REDIS_REST_URL=https://us1-xx.upstash.io
# upstash.com → Database → REST API → Token
UPSTASH_REDIS_REST_TOKEN=AX...

# ── Anthropic Claude (ต้องการเฉพาะ Live Mode) ─────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── GoldAPI (optional — Yahoo Finance ใช้ได้ฟรี) ──────────────────────────────
# goldapi.io → Dashboard → API Keys
GOLDAPI_KEY=goldapi-xxx-xxx

# ── Cron Security (ต้องการเฉพาะ Live Mode บน Vercel) ──────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your-secure-random-32-char-hex
